   "source": [
    "# SaulLM Quantization Demo (Colab)\n",
    "\n",
    "This notebook runs end-to-end latency + accuracy benchmarking for FP16, 8-bit, and 4-bit modes, and prints each model response for the provided NDA file."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "a2905594",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Fresh Colab bootstrap: clean clone + install dependencies\n",
    "# Clean up any previous failed clones\n",
    "!rm -rf saullm-quantization-project\n",
    "\n",
    "# Clone the repository\n",
    "!git clone https://github.com/moosayousaf/saullm-quantization-project.git\n",
    "\n",
    "# Move into the correctly named lowercase folder\n",
    "%cd saullm-quantization-project\n",
    "\n",
    "# Step 1: install dependencies\n",
    "!pip install -q -r requirements.txt"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "2af8e40e",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Step 2: (optional) verify GPU\n",
    "import torch\n",
    "print('CUDA available:', torch.cuda.is_available())\n",
    "if torch.cuda.is_available():\n",
    "    print('GPU:', torch.cuda.get_device_name(0))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "22cc32db",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Step 3: run benchmark script (4-bit -> 8-bit -> 16-bit with FP16 safe-offload)\n",
    "!python scripts/run_benchmark.py --precisions 4-bit,8-bit,16-bit --max-new-tokens 96 --max-input-tokens 1536 --max-gpu-memory 12GiB --max-cpu-memory 64GiB --fp16-gpu-memory 8GiB --fp16-retry-gpu-memory 6GiB\n",
    "\n",
    "# Optional: professor demo quick-run (4-bit only)\n",
    "# !python scripts/run_benchmark.py --precisions 4-bit --max-new-tokens 96 --max-input-tokens 1536 --max-gpu-memory 12GiB"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "3c5c7b05",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Step 4: display telemetry and accuracy tables\n",
    "import pandas as pd\n",
    "lat_df = pd.read_csv('outputs/metrics_log.csv')\n",
    "acc_df = pd.read_csv('outputs/accuracy_log.csv')\n",
    "display(lat_df)\n",
    "display(acc_df)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "0ebc209e",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Step 5: visualize latency per phase and precision\n",
    "import matplotlib.pyplot as plt\n",
    "pivot = lat_df.pivot(index='Phase', columns='Precision', values='Time_sec')\n",
    "pivot.plot(kind='bar', figsize=(10, 5), title='Latency by Stage and Precision')\n",
    "plt.ylabel('Seconds')\n",
    "plt.xticks(rotation=0)\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "25666ade",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Step 6: print each NDA response for demo narration\n",
    "import json\n",
    "from pathlib import Path\n",
    "\n",
    "# Load the responses\n",
    "responses = json.loads(Path('outputs/demo_responses.json').read_text())\n",
    "\n",
    "for item in responses:\n",
    "    print('=' * 100)\n",
    "    print('Precision:', item['precision'])\n",
    "    print('Accuracy:', item['accuracy'])\n",
    "    print('Response:', item['response'])\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "step7profile",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Step 7: optional architecture profile (parameters + memory estimate + layer stats)\n",
    "from src.engine.model_loader import load_model_and_tokenizer\n",
    "from src.telemetry.model_profiler import profile_model\n",
    "\n",
    "model, tokenizer = load_model_and_tokenizer(precision='4bit')\n",
    "stats = profile_model(model, print_full_layers=False)\n",
    "stats"
   ]
  }
